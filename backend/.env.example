# ─────────────────────────────────────────────────────────────
#  BankIQ Backend — Environment Configuration
#  Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string_in_production

# Embedding model and GPU
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_GPU=true

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OneDrive / Microsoft Graph
# Set USE_MOCK_ONEDRIVE=false and fill in real credentials to use Graph API
USE_MOCK_ONEDRIVE=true
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_REDIRECT_URI=http://localhost:8000/api/onedrive/callback

# Tesseract
TESSERACT_CMD=tesseract

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
